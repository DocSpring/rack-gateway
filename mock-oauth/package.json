{
  "name": "mock-oauth-server",
  "version": "1.0.0",
  "description": "Mock Google OAuth server for development",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "bunx tsc --project tsconfig.build.json",
    "start": "bun run build && bun dist/server.js",
    "dev": "bun --watch server.ts",
    "test": "bun test tests",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome format --write .",
    "typecheck": "bunx tsc -b --noEmit --pretty false"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jose": "^6.1.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.0.0",
    "bun-types": "^1.1.5",
    "typescript": "^5.9.2",
    "ultracite": "5.4.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
