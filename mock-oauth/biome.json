{
  "$schema": "https://biomejs.dev/schemas/2.3.2/schema.json",
  "extends": ["ultracite/core"],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noConsole": "off"
      },
      "style": {
        "useNamingConvention": "off",
        "noMagicNumbers": "off"
      },
      "complexity": {
        "noVoid": "off"
      }
    }
  }
}
