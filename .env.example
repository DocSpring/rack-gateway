# Copy this to .env and fill in your values for development

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_ALLOWED_DOMAIN=example.com

# JWT Configuration (optional - will auto-generate in dev mode)
# APP_JWT_KEY=your-secret-jwt-key-here

# Rack Configuration (for production - dev uses mock server)
# RACK_HOST=https://your-convox-rack.example.com
# RACK_TOKEN=your-actual-convox-rack-token
# RACK_USERNAME=convox

# Development Mode
DEV_MODE=true

# Port Configuration
PORT=8080
MOCK_CONVOX_PORT=5443

# Config Directory (where config.yml is located)
CONVOX_GATEWAY_CONFIG_DIR=./config