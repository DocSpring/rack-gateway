PORT=8080
DEV_MODE=false

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_ALLOWED_DOMAIN=docspring.com
REDIRECT_URL=https://auth.docspring.com/v1/login/callback

# JWT Configuration
APP_JWT_KEY=generate-a-secure-random-key-here

# Admin Users (comma-separated)
ADMIN_USERS=admin@docspring.com,ops@docspring.com

# Rack Tokens
RACK_TOKEN_STAGING=your-staging-rack-token
RACK_TOKEN_US=your-us-rack-token
RACK_TOKEN_EU=your-eu-rack-token

# Config Paths
RACKS_CONFIG_PATH=config/racks.yaml
USERS_CONFIG_PATH=config/users.yaml
ROLES_CONFIG_PATH=config/roles.yaml
POLICIES_PATH=config/policies.yaml