# Exclude heavy/unnecessary files from Docker build context
.git
.github
.gitignore
node_modules
bin
data
*.log
.DS_Store
.overmind.sock
tmp
.task
.renamify
ai_automation/

# other repos checked out for reference
reference/

# Web app artifacts
web/node_modules/
web/dist
web/.vite
web/test-results
web/coverage
web/playwright-report

# Dev mock oauth
mock-oauth/node_modules
mock-oauth/dist
mock-oauth/package-lock.json

# Local config/examples not needed in image
docker-compose.override.yml
mise.local.toml
mise.local.toml.example

# Tests and reports
**/*.test.*
**/coverage
