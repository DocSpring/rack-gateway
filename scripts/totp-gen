#!/usr/bin/env bash
# Wrapper for bin/totp-gen - build and run
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"
BIN="$ROOT_DIR/bin/totp-gen"

# Build if needed
if [[ ! -f "$BIN" ]] || [[ "$ROOT_DIR/cmd/totp-gen/main.go" -nt "$BIN" ]]; then
    echo "Building totp-gen..." >&2
    (cd "$ROOT_DIR" && task go:build:totp-gen)
fi

exec "$BIN" "$@"
