{
  "threshold": 0,
  "reporters": ["console"],
  "ignore": [
    "**/node_modules/**",
    "**/.pnpm/**",
    "**/dist/**",
    "**/test-results/**",
    "**/playwright-report/**",
    "**/coverage/**",
    "**/generated/**",
    "**/.jscpd/**"
  ],
  "format": ["typescript", "javascript"],
  "minLines": 10,
  "minTokens": 50,
  "output": ".jscpd",
  "exitCode": 1,
  "absolute": false,
  "gitignore": true
}
