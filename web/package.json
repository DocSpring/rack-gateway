{
  "name": "web",
  "private": true,
  "version": "0.0.9",
  "type": "module",
  "packageManager": "bun@1.3.1",
  "scripts": {
    "dev": "bunx vite --clearScreen false",
    "build": "bunx tsc -b tsconfig.build.json && bunx vite build",
    "build:fast": "bunx vite build --mode development",
    "typecheck": "bunx tsc -b --noEmit --pretty false",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "lint:unsafe": "bunx biome check --write --unsafe .",
    "knip": "bunx knip",
    "format": "bunx biome format --write .",
    "preview": "bunx vite preview",
    "test": "bunx vitest",
    "test:ui": "bunx vitest --ui",
    "test:coverage": "bunx vitest --coverage",
    "e2e": "node ./scripts/run-e2e.mjs",
    "e2e:ui": "bunx playwright test --ui",
    "generate:openapi": "bunx swagger2openapi ../internal/gateway/openapi/generated/swagger.json --outfile src/api/openapi.json --yaml=false && echo >> src/api/openapi.json",
    "generate:types": "bunx openapi-typescript src/api/openapi.json --output src/api/types.generated.ts",
    "generate:client": "bunx orval --config orval.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/react": "8.39.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-form": "^1.23.7",
    "@tanstack/react-query": "^5.90.3",
    "@tanstack/react-router": "^1.132.47",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.544.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.0",
    "react-hot-toast": "github:DocSpring/react-hot-toast#fix/csp-inline-styles-dist",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.2",
    "@types/pg": "^8.15.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "jsdom": "^27.0.0",
    "knip": "^5.66.0",
    "openapi-typescript": "^7.9.1",
    "orval": "^7.13.2",
    "otplib": "^12.0.1",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "swagger2openapi": "^7.0.8",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "ultracite": "6.0.5",
    "vite": "^7.1.9",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^3.2.4"
  }
}
