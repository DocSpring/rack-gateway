# Mock services
mock-oauth: cd mock-oauth && bun run dev
mock-convox: air -c .air-mock-convox.toml

# Gateway API (with hot reload)
gateway: LOG_LEVEL=debug DEBUG_TOPICS=http.request.info,http.response.body,sql,email air -c .air-gateway.toml

# Frontend (Vite dev server with hot reload)
web: cd web && pnpm dev
